<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuemSouEuApp.Views.ClassSummaryPage"
             Title="Turma Cadastrada">

    <Grid RowDefinitions="Auto,Auto,*" Padding="12" RowSpacing="10">

        <Frame Padding="6" CornerRadius="14" BackgroundColor="#111111" HasShadow="False">
            <Image x:Name="ClassPhotoThumb" HeightRequest="160" Aspect="AspectFit" />
        </Frame>

        <Button Grid.Row="1"
                Text="Substituir turma"
                HeightRequest="48"
                CornerRadius="14"
                Clicked="OnReplaceClicked"/>

        <CollectionView Grid.Row="2" x:Name="StudentsList" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8" ColumnDefinitions="52,*" ColumnSpacing="12">
                        <Frame Padding="0" CornerRadius="26" HeightRequest="44" WidthRequest="44" IsClippedToBounds="True">
                            <Image Source="{Binding FacePhotoPath}" Aspect="AspectFill"/>
                        </Frame>
                        <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" FontSize="16"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
