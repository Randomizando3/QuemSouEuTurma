<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuemSouEuApp.Views.GamePage"
             BackgroundColor="White"
             Title="Quem Sou Eu"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto"
          Padding="24"
          RowSpacing="18">

        <!-- TOP BAR: esquerda botões | centro logo | direita botões -->
        <Grid Grid.Row="0"
              RowDefinitions="Auto"
              ColumnDefinitions="280,*,280"
              ColumnSpacing="16">

            <!-- ESQUERDA -->
            <VerticalStackLayout Grid.Column="0" Spacing="10">
                <Button Text="Voltar"
                        BackgroundColor="Red"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="56"
                        FontSize="22"
                        Clicked="OnBackClicked"/>

                <Button Text="Novo jogo"
                        BackgroundColor="Red"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="56"
                        FontSize="22"
                        Clicked="OnNewGameClicked"/>
            </VerticalStackLayout>

            <!-- CENTRO LOGO -->
            <Grid Grid.Column="1"
                  HorizontalOptions="Center"
                  VerticalOptions="Center">
                <Image Source="logo.png"
                       HeightRequest="160"
                       Aspect="AspectFit"/>
            </Grid>

            <!-- DIREITA -->
            <VerticalStackLayout Grid.Column="2"
                                 Spacing="10"
                                 HorizontalOptions="End">
                <Button Text="Copiar QR Code"
                        BackgroundColor="Red"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="56"
                        FontSize="20"
                        Clicked="OnShowQrClicked"/>

                <Button Text="Copiar ClipBoard"
                        BackgroundColor="Red"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="56"
                        FontSize="20"
                        Clicked="OnCopyClipboardClicked"/>
            </VerticalStackLayout>
        </Grid>

        <!-- TOAST (mensagem em retângulo sobreposto) -->
        <Grid Grid.Row="1">
            <Frame x:Name="Toast"
                   IsVisible="False"
                   Opacity="0"
                   BackgroundColor="#CC000000"
                   CornerRadius="14"
                   Padding="12"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">
                <Label x:Name="ToastLabel"
                       Text=""
                       TextColor="White"
                       FontSize="18"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
            </Frame>
        </Grid>

        <!-- GRID CARTAS -->
        <CollectionView Grid.Row="2"
                        x:Name="FacesGrid"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="10"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8">

                        <Frame CornerRadius="10"
                               HasShadow="False"
                               Padding="0"
                               IsClippedToBounds="True"
                               BackgroundColor="{Binding BackColor}"
                               WidthRequest="120"
                               HeightRequest="120">

                            <Grid WidthRequest="120"
                                  HeightRequest="120">

                                <!-- PLACEHOLDER INVISÍVEL: mantém a medida fixa -->
                                <BoxView WidthRequest="120"
                                         HeightRequest="120"
                                         Opacity="0"
                                         InputTransparent="True"/>

                                <!-- FRENTE (foto do aluno) -->
                                <Image Source="{Binding FacePhotoPath}"
                                       Aspect="AspectFill"
                                       HeightRequest="120"
                                       WidthRequest="120"
                                       IsVisible="{Binding IsFaceVisible}"
                                       InputTransparent="True"/>

                                <!-- VERSO (u.png) -->
                                <Grid IsVisible="{Binding IsBackVisible}"
                                      WidthRequest="120"
                                      HeightRequest="120"
                                      InputTransparent="True">
                                    <Image Source="u.png"
                                           HeightRequest="64"
                                           WidthRequest="64"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Aspect="AspectFit"
                                           Opacity="0.90"/>
                                </Grid>

                            </Grid>
                        </Frame>

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTileTapped"/>
                        </Grid.GestureRecognizers>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- CAMPO DE RESPOSTA / SUBMIT -->
        <Frame Grid.Row="3"
               CornerRadius="14"
               BackgroundColor="#F2F2F2"
               HasShadow="False"
               Padding="12">

            <Grid ColumnDefinitions="*,160"
                  ColumnSpacing="12">

                <Entry x:Name="GuessEntry"
                       Placeholder="Quem é o aluno?"
                       FontSize="20"
                       BackgroundColor="White"
                       TextColor="#222"
                       HeightRequest="56"/>

                <Button Grid.Column="1"
                        Text="Confirmar"
                        BackgroundColor="#06D6A0"
                        TextColor="White"
                        CornerRadius="10"
                        FontSize="20"
                        HeightRequest="56"
                        Clicked="OnGuessClicked"/>
            </Grid>
        </Frame>

        <!-- OVERLAY QR (popup simples) -->
        <Grid x:Name="QrOverlay"
              IsVisible="False"
              BackgroundColor="#AA000000"
              RowDefinitions="*"
              ColumnDefinitions="*"
              InputTransparent="False">

            <Frame Padding="16"
                   CornerRadius="18"
                   BackgroundColor="White"
                   HasShadow="False"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">

                <VerticalStackLayout Spacing="12"
                                     WidthRequest="320">
                    <Label Text="QR Code do segredo"
                           FontSize="18"
                           TextColor="#222"
                           HorizontalOptions="Center"/>

                    <Image x:Name="QrImage"
                           HeightRequest="260"
                           WidthRequest="260"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"/>

                    <Button Text="Fechar"
                            BackgroundColor="Red"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="50"
                            Clicked="OnCloseQrClicked"/>
                </VerticalStackLayout>

            </Frame>
        </Grid>

    </Grid>
</ContentPage>
